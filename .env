# =========================
# APP
# =========================
NODE_ENV=development
APP_NAME=tms
APP_TIMEZONE=Asia/Ho_Chi_Minh

# =========================
# PORTS EXPOSED TO HOST
# These are the ports you map in docker-compose
# =========================
FRONTEND_PORT=5173
BACKEND_PORT=4000

# =========================
# FRONTEND
# Public URL used in browser
# =========================
FRONTEND_URL=http://localhost:5173
FRONTEND_PUBLIC_URL=
BACKEND_PUBLIC_URL=

# API URL the frontend uses from the browser
# Since browser calls go through the host-mapped port,
# use localhost here, not the Docker service name.
VITE_API_URL=http://localhost:4000/api

# If not using Vite, keep one of these only if needed
NEXT_PUBLIC_API_URL=http://localhost:4000/api
PUBLIC_API_URL=http://localhost:4000/api

# =========================
# BACKEND
# Inside Docker, backend should bind to all interfaces
# =========================
BACKEND_HOST=0.0.0.0
BACKEND_URL=http://localhost:4000
API_PREFIX=/api

# =========================
# DATABASE (Azure SQL Database / SQL Server)
# Fill these with values from Azure Portal.
# Required:
# - DB_HOST: Azure SQL server host, e.g. tms-database.database.windows.net
# - DB_PORT: usually 1433
# - DB_NAME: Azure SQL database name
# - DB_USER: SQL server login/user
# - DB_PASSWORD: database password
# - DB_ENCRYPT: keep true for Azure SQL
# - DB_TRUST_SERVER_CERTIFICATE: keep false for Azure SQL
# =========================
DB_CLIENT=mssql
DB_HOST=tms-database.database.windows.net
DB_PORT=1433
DB_NAME=tms-database
DB_USER=sqladmin
DB_PASSWORD=admin123$
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false
# Keep true for first run on an empty Azure SQL database so TypeORM creates tables.
# Set false after the schema exists.
DB_SYNCHRONIZE=true
DB_DROP_SCHEMA=true

# This app reads DB_* above. DATABASE_URL is kept for tools that need one.
# URL-encode DB_USER/DB_PASSWORD here if they contain @, :, /, ?, #, or spaces.
DATABASE_URL=sqlserver://sqladmin:admin123$@tms-database.database.windows.net:1433?database=tms-database&encrypt=true

# =========================
# AUTH - JWT ONLY
# Stateless auth, no refresh tokens
# =========================
JWT_SECRET=7f3a9c1d8e4b6a2f5d9e1c7b3a8f4d2c6e1b9a5f7d3c8e2a4b6f1d9c7e3a5b2
CREDENTIAL_SECRET=local-discord-credential-secret
JWT_EXPIRES_IN=1d
JWT_ISSUER=backend
JWT_AUDIENCE=frontend
AUTH_ALLOW_PUBLIC_REGISTRATION=false
SYSADMIN_USERNAME=admin
SYSADMIN_PASSWORD=admin12345

# =========================
# PASSPORT
# For passport-jwt, not passport session
# =========================
PASSPORT_SESSION_ENABLED=false

# =========================
# PASSWORD HASHING
# =========================
BCRYPT_SALT_ROUNDS=12

# =========================
# CORS
# Browser origin allowed to call backend
# =========================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false

# =========================
# LOGGING
# =========================
LOG_LEVEL=debug

# =========================
# OPTIONAL SECURITY / RATE LIMIT
# =========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
TRUST_PROXY=false

# =========================
# BACKGROUND SYNC JOBS
# =========================
AUTO_SYNC_ENABLED=true
AUTO_SYNC_INTERVAL_SECONDS=15
AUTO_SYNC_DISCORD_ENABLED=true
AUTO_SYNC_CODEFORCES_ENABLED=true
SESSION_STATUS_SYNC_ENABLED=true
SESSION_STATUS_SYNC_INTERVAL_SECONDS=15
VOICE_ATTENDANCE_SYNC_ENABLED=true
VOICE_ATTENDANCE_SYNC_INTERVAL_SECONDS=15
CODEFORCES_STANDING_SYNC_INTERVAL_SECONDS=15
