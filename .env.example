# =========================
# APP
# =========================
NODE_ENV=development
APP_NAME=tms
APP_TIMEZONE=Asia/Ho_Chi_Minh
FRONTEND_URL=http://localhost:4000
BACKEND_URL=http://localhost:4000
VITE_API_URL=/api
DISCORD_FALLBACK_URL=http://localhost:4000

# =========================
# PORT EXPOSED BY THE MONOLITH CONTAINER
# =========================
BACKEND_PORT=4000

# =========================
# BACKEND
# Inside Docker, backend should bind to all interfaces
# =========================
BACKEND_HOST=0.0.0.0
API_PREFIX=/api

# =========================
# DATABASE (Azure SQL Database / SQL Server)
# Fill these with values from Azure Portal.
# Required:
# - DB_HOST: Azure SQL server host, e.g. tms-database.database.windows.net
# - DB_PORT: usually 1433
# - DB_NAME: Azure SQL database name
# - DB_USER: SQL server login/user
# - DB_PASSWORD: database password
# - DB_ENCRYPT: keep true for Azure SQL
# - DB_TRUST_SERVER_CERTIFICATE: keep false for Azure SQL
# =========================
DB_CLIENT=mssql
DB_HOST=tms-database.database.windows.net
DB_PORT=1433
DB_NAME=tms-database
DB_USER=sqladmin
DB_PASSWORD=admin123$
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false
# Keep true for first run on an empty Azure SQL database so TypeORM creates tables.
# Set false after the schema exists.
DB_SYNCHRONIZE=true
DB_DROP_SCHEMA=true

# This app reads DB_* above. DATABASE_URL is kept for tools that need one.
# URL-encode DB_USER/DB_PASSWORD here if they contain @, :, /, ?, #, or spaces.
DATABASE_URL=sqlserver://sqladmin:admin123$@tms-database.database.windows.net:1433?database=tms-database&encrypt=true

# =========================
# AUTH - JWT ONLY
# Stateless auth, no refresh tokens
# =========================
JWT_SECRET=7f3a9c1d8e4b6a2f5d9e1c7b3a8f4d2c6e1b9a5f7d3c8e2a4b6f1d9c7e3a5b2
CREDENTIAL_SECRET=local-discord-credential-secret
JWT_EXPIRES_IN=1d
JWT_ISSUER=backend
JWT_AUDIENCE=frontend
AUTH_ALLOW_PUBLIC_REGISTRATION=false
SYSADMIN_USERNAME=admin
SYSADMIN_PASSWORD=admin12345

# =========================
# PASSPORT
# For passport-jwt, not passport session
# =========================
PASSPORT_SESSION_ENABLED=false

# =========================
# PASSWORD HASHING
# =========================
BCRYPT_SALT_ROUNDS=12

# =========================
# LOGGING
# =========================
LOG_LEVEL=debug

# =========================
# OPTIONAL SECURITY / RATE LIMIT
# =========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
TRUST_PROXY=false

# =========================
# BACKGROUND WORKERS
# =========================
SYNC_INTERVAL_SECONDS=15
