@startuml
left to right direction
actor "Teacher" as Teacher
actor "Admin" as Admin
rectangle "Identity Module" {
  usecase "Submit username/password" as UC1
  usecase "Validate credential" as UC2
  usecase "Check account status" as UC3
  usecase "Issue JWT access token" as UC4
  usecase "Reject invalid login" as UC5
  usecase "Load current teacher profile" as UC6
  usecase "Update my profile" as UC7
}
Teacher --> UC1
Admin --> UC1
Teacher --> UC6
Teacher --> UC7
Admin --> UC6
Admin --> UC7
UC1 .> UC2 : include
UC2 .> UC3 : include
UC3 .> UC4 : include
UC2 .> UC5 : extend
UC3 .> UC5 : extend
@enduml
