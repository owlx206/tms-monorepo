@startuml
left to right direction
actor "Discord Classroom Sync Worker" as Worker
actor "Discord Gateway" as Gateway
rectangle "Classroom Module" {
  usecase "Find open voice sessions" as UC1
  usecase "Connect bot client" as UC2
  usecase "Collect voice members" as UC3
  usecase "Match Discord credential to student" as UC4
  usecase "Mark bot attendance" as UC5
  usecase "Respect manual attendance" as UC6
}
rectangle "Finance Module" {
  usecase "Sync charged fee record" as UC7
}
Worker --> UC1
Gateway --> UC2
UC1 .> UC2 : include
UC2 .> UC3 : include
UC3 .> UC4 : include
UC4 .> UC5 : include
UC5 .> UC6 : include
UC5 .> UC7 : include
@enduml
