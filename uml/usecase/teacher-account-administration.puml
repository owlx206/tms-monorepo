@startuml
left to right direction
actor "Sysadmin" as Admin
rectangle "Identity" {
  usecase "List teachers" as UC1
  usecase "Update teacher account" as UC2
  usecase "Change role or active status" as UC3
  usecase "Reset teacher password" as UC4
  usecase "Configure system Discord bot" as UC5
  usecase "Check bot credential health" as UC6
}
Admin --> UC1
Admin --> UC2
Admin --> UC5
UC2 .> UC3 : include
UC2 .> UC4 : extend
UC5 .> UC6 : include
@enduml
