@startuml
left to right direction
actor "Teacher" as Teacher
actor "Student" as Student
actor "Discord OAuth2" as OAuth
rectangle "Identity" {
  usecase "Build student authorize URL" as UC1
  usecase "Verify student state" as UC2
  usecase "Exchange OAuth code" as UC3
  usecase "Fetch student Discord user" as UC4
  usecase "Save student Discord identity" as UC5
  usecase "Save student OAuth token" as UC6
  usecase "Return popup callback HTML" as UC7
}
Teacher --> UC1
Student --> UC2
UC2 .> UC3 : include
UC3 .> OAuth : calls
UC3 .> UC4 : include
UC4 .> UC5 : include
UC5 .> UC6 : include
UC6 .> UC7 : include
@enduml
