@startuml
actor "Codeforces Gym Sync Worker" as Runner
participant "syncCodeforcesGymsOnce" as Job
participant "TypeOrmGymReader" as R
participant "CodeforcesGym" as Gym
participant "CodeforcesClient singleton" as CF
participant "TypeOrmGymWriter" as W
database "class_gyms/gym_problems/gym_standings/teacher_codeforces_credentials" as DB
Runner -> Job : run()
Job -> R : listBoundCodeforcesGymsForTeacher()
R -> DB : SELECT class gyms + credentials
loop each teacher credential
  Job -> Gym : listOwnedGyms(ownerHandle)
  Gym -> CF : request contest.list with rate limit
  CF --> Gym : visible gyms
  Job -> W : syncCodeforcesGymCatalog(raw gyms)
  W -> DB : UPSERT class_gyms cache rows
end
loop each bound gym
  Job -> Gym : getGymSnapshot(gymId)
  Gym -> CF : contest.standings
  CF --> Gym : contest + problems + rows
  alt snapshot fetched
    Job -> W : syncCodeforcesGymStandingProjection(snapshot)
    W -> DB : UPSERT gym_problems and standings
  else API failed
    Job -> Job : skip
  end
end
Job --> Runner : complete
@enduml
