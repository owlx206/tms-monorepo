@startuml
actor Sysadmin
participant "Admin API" as C
participant "Update teacher" as U
participant "Teacher storage" as W
participant "Password hasher" as H
participant "Configure Discord bot" as DU
database "teachers" as T
database "sysadmin_discord_bot_credentials" as D

Sysadmin -> C : PATCH /admin/teachers/{teacherId}
C -> U : execute(teacherId, input)
U -> W : requireById(teacherId)
W -> T : SELECT teacher
T --> W : Teacher
alt password provided
  U -> H : hash(password)
  H --> U : password_hash
end
U -> W : save(updated teacher)
W -> T : UPDATE teachers
U --> C : Teacher account
C --> Sysadmin : 200

Sysadmin -> C : PUT /admin/discord-bot
C -> DU : execute(input)
DU -> W : load current bot credential
W -> D : SELECT bot credential
DU -> W : save credential + invite settings
W -> D : INSERT/UPDATE credential
DU --> C : Discord bot credential
C --> Sysadmin : 200
@enduml
