@startuml
left to right direction
actor "Teacher" as T
actor "Scheduler" as W
rectangle "Attendance API" as P1
rectangle "Attendance update" as P2
rectangle "Session attendance sync" as P3
database "sessions/classes" as D1
database "students/enrollments" as D2
database "attendance" as D3
database "fee_records" as D4
T --> P1 : manual attendance status/notes
P1 --> P2 : attendance command
W --> P3 : status/materialization sync
P2 --> D1 : load session and class
P2 --> D2 : load student and enrollment at session time
D1 --> P2 : fee/session status
D2 --> P2 : valid enrollment
P2 --> D3 : insert/update manual attendance
P3 --> D3 : materialize default attendance rows
P2 --> P3 : fee projection command
P3 --> D4 : upsert/delete fee record
P1 --> T : Attendance record
@enduml
