@startuml
left to right direction
actor "Sysadmin" as A
rectangle "Admin API" as P1
rectangle "Teacher administration" as P2
rectangle "Password Hasher" as P3
rectangle "Discord bot configuration" as P4
database "teachers" as D1
database "sysadmin_discord_bot_credentials" as D2
A --> P1 : teacher filter/update or bot settings
P1 --> P2 : teacher command
P2 --> D1 : read/update teacher
D1 --> P2 : teacher row
P2 --> P3 : password when reset
P3 --> P2 : password_hash
P2 --> P1 : teacher view/list
P1 --> P4 : bot credential command
P4 --> D2 : insert/update bot credential
D2 --> P4 : stored bot credential
P1 --> A : response
@enduml
