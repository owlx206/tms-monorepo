@startuml
object User
object "Auth API" as AuthAPI
object Login
object "Teacher storage" as TeacherStorage
object "Password hasher" as PasswordHasher
object "Access token signer" as AccessTokenSigner
object Teachers <<database>>
User --> AuthAPI : 1: POST credentials
AuthAPI --> Login : 2: execute
Login --> TeacherStorage : 3: findByUsername
TeacherStorage --> Teachers : 4: SELECT teacher
Login --> PasswordHasher : 5: compare password
Login --> AccessTokenSigner : 6: sign claims
Login --> AuthAPI : 7: auth result/error
AuthAPI --> User : 8: response
User --> AuthAPI : 9: GET /me
AuthAPI --> TeacherStorage : 10: load current teacher
TeacherStorage --> Teachers : 11: SELECT teacher
@enduml
